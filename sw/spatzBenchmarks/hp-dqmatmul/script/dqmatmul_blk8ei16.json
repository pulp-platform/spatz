    kernel: "VQ-GEMM"
    tag: "blk8ei16",
    num_codebooks: 2,
    M: 128,
    N: 128,
    K: 128,
    alpha: 0,
    transpose_A: false,
    transpose_B: false,
    prec: 16,
    expand: 0,
    CB0_N: 65536,
    CB0_D: 8,
    CB1_N: 65536,
    CB1_D: 8,
    CB0_IDX_WIDTH: 2,
    CB1_IDX_WIDTH: 2
}
